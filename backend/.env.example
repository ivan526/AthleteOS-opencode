# AthleteOS 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改

# ==========================================
# 数据库配置
# ==========================================
DATABASE_URL=sqlite:///./athleteos.db

# PostgreSQL 示例 (可选)
# DATABASE_URL=postgresql://user:password@localhost:5432/athleteos

# ==========================================
# JWT 认证配置
# ==========================================
# 生产环境请使用强随机字符串生成密钥
# 可以用: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# Token 过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================
# 前端配置
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ==========================================
# 可选配置
# ==========================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS 允许的源 (逗号分隔)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
